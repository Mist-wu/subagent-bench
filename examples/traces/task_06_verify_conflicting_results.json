{
  "events": [
    {
      "type": "delegate",
      "delegation_id": "risk-review-a",
      "assignee": "frontend_reviewer",
      "instruction": "Review rollout risk and summarize whether it is safe.",
      "inputs": ["reports/frontend-risk.md"],
      "constraints": ["Read only"],
      "success_criteria": ["State safe or unsafe"],
      "output_path": "reports/review_a.md"
    },
    {
      "type": "delegate",
      "delegation_id": "risk-review-b",
      "assignee": "backend_reviewer",
      "instruction": "Review rollout risk and summarize whether it is safe.",
      "inputs": ["reports/backend-risk.md"],
      "constraints": ["Read only"],
      "success_criteria": ["State safe or unsafe"],
      "output_path": "reports/review_b.md"
    },
    {
      "type": "subagent_result",
      "delegation_id": "risk-review-a",
      "status": "success",
      "summary": "Safe to roll out."
    },
    {
      "type": "subagent_result",
      "delegation_id": "risk-review-b",
      "status": "success",
      "summary": "Unsafe to roll out until policy exception is approved."
    },
    {
      "type": "verification",
      "source": "docs/rollout-policy.md",
      "reason": "Subagent conclusions conflict."
    },
    {
      "type": "artifact_written",
      "path": "reports/final_decision.md"
    }
  ]
}
